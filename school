<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <meta name="description" content="Sistem peminjaman fasilitas sekolah modern - SmartFacility.id">
    <meta name="author" content="SmartFacility School">
    <title>SmartFacility.id | Peminjaman Fasilitas Sekolah</title>
    
    <!-- SEO & Favicon -->
    <link rel="canonical" href="https://www.smartfacility.id">
    <link rel="icon" type="image/x-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏫</text></svg>">
    
    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    
    <style>
        /* [SAME EXCELLENT STYLES AS PREVIOUS CODE - keeping all styling] */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(145deg, #eef2ff 0%, #e0e7ff 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .app-container {
            max-width: 1400px;
            width: 100%;
            background: rgba(255,255,255,0.35);
            backdrop-filter: blur(2px);
            border-radius: 48px;
            padding: 20px;
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.25);
        }

        .glass-card {
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(12px);
            border-radius: 40px;
            box-shadow: 0 20px 35px -10px rgba(0,0,0,0.1), inset 0 1px 0 rgba(255,255,255,0.6);
            padding: 32px;
            transition: all 0.2s ease;
        }

        .login-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 28px;
            justify-content: center;
        }

        .login-card {
            flex: 1;
            min-width: 280px;
            background: white;
            border-radius: 32px;
            padding: 28px 24px;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 10px 20px -5px rgba(0,0,0,0.08);
            border: 1px solid rgba(255,255,255,0.5);
            cursor: pointer;
        }

        .login-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 24px 36px -12px rgba(0,0,0,0.2);
        }

        .badge-icon {
            background: #4f46e5;
            width: 56px;
            height: 56px;
            border-radius: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            color: white;
            font-size: 26px;
        }

        h2 {
            font-size: 1.8rem;
            font-weight: 700;
            background: linear-gradient(135deg, #1e293b, #2d3a5e);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .input-group {
            margin: 20px 0 16px;
        }

        input, select, textarea {
            width: 100%;
            padding: 14px 18px;
            border: 1.5px solid #e2e8f0;
            border-radius: 28px;
            font-size: 0.95rem;
            transition: all 0.2s;
            background: #f9fafc;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79,70,229,0.2);
        }

        .btn-primary {
            background: linear-gradient(105deg, #4f46e5, #7c3aed);
            border: none;
            color: white;
            font-weight: 600;
            padding: 14px 20px;
            border-radius: 40px;
            width: 100%;
            cursor: pointer;
            font-size: 1rem;
            transition: 0.2s;
            box-shadow: 0 4px 10px rgba(79,70,229,0.3);
        }

        .btn-primary:hover {
            transform: scale(0.98);
            background: linear-gradient(105deg, #4338ca, #6d28d9);
        }

        .btn-outline {
            background: transparent;
            border: 2px solid #cbd5e1;
            border-radius: 40px;
            padding: 12px 24px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-outline:hover {
            border-color: #4f46e5;
            background: #f1f5f9;
        }

        .admin-pw-wrapper {
            position: relative;
        }

        .toggle-pw {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #64748b;
        }

        .dashboard {
            display: none;
        }

        .dashboard.active {
            display: block;
            animation: fadeUp 0.4s ease;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(15px);}
            to { opacity: 1; transform: translateY(0);}
        }

        .booking-form {
            background: white;
            border-radius: 32px;
            padding: 28px;
            margin-top: 20px;
        }

        .form-row {
            display: flex;
            flex-wrap: wrap;
            gap: 18px;
            margin-bottom: 18px;
        }

        .form-row .field {
            flex: 1;
            min-width: 180px;
        }

        .bookings-list {
            margin-top: 28px;
        }

        .booking-item {
            background: #f8fafc;
            border-radius: 24px;
            padding: 20px;
            margin-bottom: 16px;
            border-left: 8px solid #4f46e5;
            transition: all 0.2s;
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: center;
        }

        .booking-info p {
            margin: 6px 0;
        }

        .status-badge {
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 700;
            background: #f1f5f9;
        }

        .status-diproses { background: #fef9c3; color: #854d0e;}
        .status-disetujui { background: #dcfce7; color: #166534;}
        .status-ditolak { background: #ffe4e2; color: #b91c1c;}

        .admin-actions button {
            margin: 0 6px;
            padding: 8px 18px;
            border-radius: 30px;
            border: none;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-approve { background: #10b981; color: white;}
        .btn-reject { background: #ef4444; color: white;}
        .btn-cancel { background: #94a3b8; color: white;}

        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .logout-btn {
            background: rgba(0,0,0,0.05);
            border: none;
            padding: 10px 20px;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

        .logout-btn:hover {
            background: rgba(0,0,0,0.1);
        }

        .greeting {
            font-weight: 600;
            font-size: 1.4rem;
        }
        
        i {
            margin-right: 8px;
        }
        
        footer {
            text-align: center;
            margin-top: 32px;
            font-size: 0.8rem;
            color: #475569;
        }
        
        @media (max-width: 760px) {
            .glass-card { padding: 20px; }
            .booking-item { flex-direction: column; align-items: flex-start; gap: 12px;}
        }

        /* Loading animation */
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,.3);
            border-radius: 50%;
            border-top-color: white;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
<div class="app-container" id="app">
    <!-- [REST OF THE HTML STRUCTURE SAME AS PREVIOUS CODE] -->
    <div id="loginScreen" class="glass-card">
        <div style="text-align: center; margin-bottom: 28px;">
            <i class="fas fa-school" style="font-size: 48px; color: #4f46e5;"></i>
            <h1 style="font-weight: 800; margin-top: 8px;">SmartFacility<span style="color:#4f46e5;">.id</span></h1>
            <p style="color: #334155;">Sistem Peminjaman Fasilitas Sekolah • Modern & Cepat</p>
            <p style="font-size: 12px; margin-top: 8px; color: #64748b;">
                <i class="fas fa-globe"></i> www.smartfacility.id
            </p>
        </div>
        <div class="login-grid">
            <div class="login-card" id="siswaCard">
                <div class="badge-icon"><i class="fas fa-user-graduate"></i></div>
                <h2>Siswa Area</h2>
                <p style="margin: 12px 0 20px; color:#475569;">Langsung masuk & ajukan peminjaman</p>
                <button id="siswaLoginBtn" class="btn-primary"><i class="fas fa-arrow-right-to-bracket"></i> Masuk sebagai Siswa</button>
            </div>
            <div class="login-card">
                <div class="badge-icon"><i class="fas fa-shield-alt"></i></div>
                <h2>Admin Panel</h2>
                <div class="input-group">
                    <div class="admin-pw-wrapper">
                        <input type="password" id="adminPassword" placeholder="Password Admin" autocomplete="off">
                        <span class="toggle-pw" onclick="toggleAdminPassword()"><i class="far fa-eye-slash" id="pwToggleIcon"></i></span>
                    </div>
                </div>
                <button id="adminLoginBtn" class="btn-primary"><i class="fas fa-lock"></i> Login Admin</button>
                <p style="font-size: 12px; margin-top: 16px; color: #475569;"><i class="fas fa-key"></i> *Akses khusus petugas sekolah</p>
            </div>
        </div>
    </div>

    <div id="siswaDashboard" class="dashboard glass-card">
        <div class="navbar">
            <div class="greeting"><i class="fas fa-grin-tongue-squint"></i> Hallo, <span id="siswaNameDisplay"></span>!</div>
            <button id="logoutSiswa" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Keluar</button>
        </div>
        <div class="booking-form">
            <h3><i class="fas fa-calendar-alt"></i> Formulir Peminjaman Fasilitas</h3>
            <div class="form-row">
                <div class="field"><input type="text" id="namaPeminjam" placeholder="Nama Lengkap" required></div>
                <div class="field"><input type="text" id="kelas" placeholder="Kelas (contoh: XII IPA 1)"></div>
            </div>
            <div class="form-row">
                <div class="field"><input type="text" id="keperluan" placeholder="Keperluan (contoh: rapat OSIS, praktikum)"></div>
                <div class="field">
                    <select id="ruangan">
                        <option value="Lab Komputer">💻 Lab Komputer</option>
                        <option value="Aula Serbaguna">🏛️ Aula Serbaguna</option>
                        <option value="Lapangan Basket">🏀 Lapangan Basket</option>
                        <option value="Ruang Kelas Theater">🎭 Ruang Kelas Theater</option>
                        <option value="Perpustakaan Digital">📚 Perpustakaan Digital</option>
                        <option value="Musik & Seni">🎵 Ruang Musik & Seni</option>
                    </select>
                </div>
            </div>
            <div class="form-row">
                <div class="field"><input type="text" id="jamMulai" placeholder="Jam mulai (contoh: 09:00)"></div>
                <div class="field"><input type="text" id="jamSelesai" placeholder="Jam selesai (contoh: 11:00)"></div>
            </div>
            <div class="form-row">
                <div class="field">
                    <input type="text" id="tanggalPinjam" placeholder="Pilih Tanggal Pinjam" readonly>
                </div>
            </div>
            <button id="submitPinjamBtn" class="btn-primary"><i class="fas fa-pen-fancy"></i> Ajukan Peminjaman</button>
        </div>
        <div class="bookings-list">
            <h3><i class="fas fa-list-ul"></i> Riwayat & Peminjaman Saya</h3>
            <div id="siswaBookingsContainer">Loading...</div>
        </div>
    </div>

    <div id="adminDashboard" class="dashboard glass-card">
        <div class="navbar">
            <div class="greeting"><i class="fas fa-crown"></i> Admin Panel • Manajemen Peminjaman</div>
            <button id="logoutAdmin" class="logout-btn"><i class="fas fa-door-open"></i> Keluar Admin</button>
        </div>
        <div id="adminStats" style="background: white; border-radius: 24px; padding: 16px; margin-bottom: 20px;"></div>
        <div id="adminRequestsList" style="margin-top: 16px;"></div>
    </div>
</div>
<footer>
    <i class="fas fa-copyright"></i> 2025 SmartFacility.id — Sistem Manajemen Fasilitas Sekolah | 
    <i class="fas fa-shield-alt"></i> Aman & Terpercaya
</footer>

<script>
    let peminjaman = [];
    const STORAGE_KEY = "smartfacility_school";
    const ADMIN_PASSWORD = "123467";
    let currentSiswaName = null;

    function loadData() {
        const stored = localStorage.getItem(STORAGE_KEY);
        if(stored) {
            peminjaman = JSON.parse(stored);
        } else {
            peminjaman = [
                { id: "1", nama: "Arjuna Pratama", kelas: "XI MIPA 2", keperluan: "Latihan Debat", ruangan: "Aula Serbaguna", jamMulai: "10:00", jamSelesai: "12:00", tanggal: "2025-03-20", status: "disetujui", tanggalDibuat: "2025-03-18" },
                { id: "2", nama: "Nadine Kirana", kelas: "XII IPS 1", keperluan: "Presentasi Tugas", ruangan: "Lab Komputer", jamMulai: "13:00", jamSelesai: "14:30", tanggal: "2025-03-22", status: "diproses", tanggalDibuat: "2025-03-19" }
            ];
            saveData();
        }
    }
    
    function saveData() {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(peminjaman));
    }

    function formatTanggal(tgl) {
        if(!tgl) return "-";
        let parts = tgl.split("-");
        if(parts.length===3) return `${parts[2]}/${parts[1]}/${parts[0]}`;
        return tgl;
    }
    
    function getCurrentDate() {
        let today = new Date();
        let yyyy = today.getFullYear();
        let mm = String(today.getMonth()+1).padStart(2,'0');
        let dd = String(today.getDate()).padStart(2,'0');
        return `${yyyy}-${mm}-${dd}`;
    }

    function renderSiswaBookings() {
        if(!currentSiswaName) {
            document.getElementById("siswaBookingsContainer").innerHTML = `<div class="booking-item">Belum ada data, silakan ajukan peminjaman</div>`;
            return;
        }
        let myBookings = peminjaman.filter(p => p.nama === currentSiswaName);
        if(myBookings.length === 0) {
            document.getElementById("siswaBookingsContainer").innerHTML = `<div class="booking-item"><i class="fas fa-info-circle"></i> Belum ada pengajuan dari akun Anda.</div>`;
            return;
        }
        let html = "";
        myBookings.forEach(p => {
            let statusClass = "";
            if(p.status === "diproses") statusClass = "status-diproses";
            else if(p.status === "disetujui") statusClass = "status-disetujui";
            else if(p.status === "ditolak") statusClass = "status-ditolak";
            html += `
                <div class="booking-item">
                    <div class="booking-info">
                        <p><strong><i class="fas fa-door-open"></i> ${p.ruangan}</strong></p>
                        <p><i class="fas fa-user"></i> Kelas: ${p.kelas} | ${p.keperluan}</p>
                        <p><i class="fas fa-clock"></i> ${p.jamMulai} - ${p.jamSelesai} &nbsp;| <i class="fas fa-calendar-day"></i> ${formatTanggal(p.tanggal)}</p>
                        <p><i class="fas fa-calendar-week"></i> Diajukan: ${p.tanggalDibuat} &nbsp; <span class="status-badge ${statusClass}"><i class="fas fa-flag-checkered"></i> ${p.status.toUpperCase()}</span></p>
                    </div>
                    <div class="admin-actions">
                        ${p.status === "diproses" ? `<button class="btn-cancel" onclick="cancelBooking('${p.id}')"><i class="fas fa-trash-alt"></i> Batalkan</button>` : `<button disabled style="opacity:0.5; background:#cbd5e1;" class="btn-cancel">Tidak bisa batal</button>`}
                    </div>
                </div>
            `;
        });
        document.getElementById("siswaBookingsContainer").innerHTML = html;
    }

    function cancelBooking(id) {
        let index = peminjaman.findIndex(p => p.id === id);
        if(index !== -1 && peminjaman[index].status === "diproses") {
            peminjaman.splice(index,1);
            saveData();
            renderSiswaBookings();
            if(document.getElementById("adminDashboard").classList.contains("active")) renderAdminPanel();
            showToast("✅ Peminjaman berhasil dibatalkan.", "success");
        } else {
            showToast("Tidak dapat membatalkan status ini.", "error");
        }
    }

    function submitPeminjamanSiswa() {
        if(!currentSiswaName) {
            showToast("Sesi siswa error, silakan login ulang.", "error");
            return;
        }
        let nama = document.getElementById("namaPeminjam").value.trim();
        let kelas = document.getElementById("kelas").value.trim();
        let keperluan = document.getElementById("keperluan").value.trim();
        let ruangan = document.getElementById("ruangan").value;
        let jamMulai = document.getElementById("jamMulai").value.trim();
        let jamSelesai = document.getElementById("jamSelesai").value.trim();
        let tanggal = document.getElementById("tanggalPinjam").value;

        if(!nama || !kelas || !keperluan || !jamMulai || !jamSelesai || !tanggal) {
            showToast("⚠️ Lengkapi semua field peminjaman!", "error");
            return;
        }
        if(nama !== currentSiswaName) {
            showToast("Nama harus sesuai dengan login siswa", "error");
            return;
        }
        let newId = Date.now().toString();
        let todayDate = getCurrentDate();
        let newBooking = {
            id: newId,
            nama: nama,
            kelas: kelas,
            keperluan: keperluan,
            ruangan: ruangan,
            jamMulai: jamMulai,
            jamSelesai: jamSelesai,
            tanggal: tanggal,
            status: "diproses",
            tanggalDibuat: todayDate
        };
        peminjaman.push(newBooking);
        saveData();
        document.getElementById("kelas").value = "";
        document.getElementById("keperluan").value = "";
        document.getElementById("jamMulai").value = "";
        document.getElementById("jamSelesai").value = "";
        document.getElementById("tanggalPinjam").value = "";
        renderSiswaBookings();
        if(document.getElementById("adminDashboard").classList.contains("active")) renderAdminPanel();
        showToast("✨ Pengajuan berhasil! Menunggu persetujuan admin.", "success");
    }

    function renderAdminPanel() {
        const pendingCount = peminjaman.filter(p => p.status === "diproses").length;
        const approvedCount = peminjaman.filter(p => p.status === "disetujui").length;
        const rejectedCount = peminjaman.filter(p => p.status === "ditolak").length;
        
        document.getElementById("adminStats").innerHTML = `
            <div style="display: flex; gap: 16px; flex-wrap: wrap; justify-content: space-around;">
                <div style="text-align: center;"><div style="font-size: 32px; font-weight: 800; color:#f59e0b;">${pendingCount}</div><div>Menunggu</div></div>
                <div style="text-align: center;"><div style="font-size: 32px; font-weight: 800; color:#10b981;">${approvedCount}</div><div>Disetujui</div></div>
                <div style="text-align: center;"><div style="font-size: 32px; font-weight: 800; color:#ef4444;">${rejectedCount}</div><div>Ditolak</div></div>
            </div>
        `;
        
        if(peminjaman.length === 0) {
            document.getElementById("adminRequestsList").innerHTML = `<div class="booking-item">Belum ada data peminjaman.</div>`;
            return;
        }
        let html = `<h3><i class="fas fa-clipboard-list"></i> Seluruh Pengajuan Peminjaman</h3>`;
        peminjaman.forEach(p => {
            let statusClass = "";
            if(p.status === "diproses") statusClass = "status-diproses";
            else if(p.status === "disetujui") statusClass = "status-disetujui";
            else if(p.status === "ditolak") statusClass = "status-ditolak";
            html += `
                <div class="booking-item">
                    <div style="flex:2">
                        <p><strong><i class="fas fa-user-circle"></i> ${p.nama} (${p.kelas})</strong></p>
                        <p><i class="fas fa-building"></i> ${p.ruangan} | ${p.keperluan}</p>
                        <p><i class="fas fa-hourglass-half"></i> ${p.jamMulai} - ${p.jamSelesai} | ${formatTanggal(p.tanggal)}</p>
                        <p><i class="fas fa-calendar-plus"></i> Diajukan: ${p.tanggalDibuat}  <span class="status-badge ${statusClass}">${p.status}</span></p>
                    </div>
                    <div class="admin-actions">
                        ${p.status === "diproses" ? `<button class="btn-approve" onclick="updateStatus('${p.id}','disetujui')"><i class="fas fa-check-circle"></i> Setujui</button>
                        <button class="btn-reject" onclick="updateStatus('${p.id}','ditolak')"><i class="fas fa-times-circle"></i> Tolak</button>` : `<span style="font-size:13px;">Sudah direspon</span>`}
                    </div>
                </div>
            `;
        });
        document.getElementById("adminRequestsList").innerHTML = html;
    }

    function updateStatus(id, newStatus) {
        let idx = peminjaman.findIndex(p => p.id === id);
        if(idx !== -1) {
            peminjaman[idx].status = newStatus;
            saveData();
            renderAdminPanel();
            if(document.getElementById("siswaDashboard").classList.contains("active") && currentSiswaName) renderSiswaBookings();
            showToast(`Status berhasil diubah menjadi ${newStatus}`, "info");
        }
    }

    function showToast(msg, type) {
        let toastDiv = document.createElement("div");
        toastDiv.style.position = "fixed";
        toastDiv.style.bottom = "30px";
        toastDiv.style.left = "50%";
        toastDiv.style.transform = "translateX(-50%)";
        toastDiv.style.backgroundColor = type === "error" ? "#ef4444" : (type==="success"?"#10b981":"#3b82f6");
        toastDiv.style.color = "white";
        toastDiv.style.padding = "12px 28px";
        toastDiv.style.borderRadius = "40px";
        toastDiv.style.fontWeight = "600";
        toastDiv.style.zIndex = "9999";
        toastDiv.style.boxShadow = "0 10px 20px rgba(0,0,0,0.2)";
        toastDiv.style.backdropFilter = "blur(8px)";
        toastDiv.innerText = msg;
        document.body.appendChild(toastDiv);
        setTimeout(() => { toastDiv.remove(); }, 2800);
    }

    function toggleAdminPassword() {
        let pwField = document.getElementById("adminPassword");
        let icon = document.getElementById("pwToggleIcon");
        if(pwField.type === "password") {
            pwField.type = "text";
            icon.className = "far fa-eye";
        } else {
            pwField.type = "password";
            icon.className = "far fa-eye-slash";
        }
    }

    function initFlatpickr() {
        flatpickr("#tanggalPinjam", {
            dateFormat: "Y-m-d",
            minDate: "today",
            disableMobile: true,
            altInput: true,
            altFormat: "d F Y",
            placeholder: "📅 Pilih tanggal peminjaman"
        });
    }

    function studentLogin() {
        let namaStudent = prompt("Masukkan namamu untuk melanjutkan peminjaman:", "Rania Azzahra");
        if(namaStudent && namaStudent.trim() !== "") {
            currentSiswaName = namaStudent.trim();
            document.getElementById("loginScreen").style.display = "none";
            document.getElementById("siswaDashboard").classList.add("active");
            document.getElementById("adminDashboard").classList.remove("active");
            document.getElementById("namaPeminjam").value = currentSiswaName;
            document.getElementById("siswaNameDisplay").innerText = currentSiswaName;
            renderSiswaBookings();
            showToast(`Selamat datang, ${currentSiswaName}! ✨`, "success");
        } else {
            showToast("Nama tidak boleh kosong", "error");
        }
    }

    function adminLogin() {
        let pass = document.getElementById("adminPassword").value;
        if(pass === ADMIN_PASSWORD) {
            document.getElementById("loginScreen").style.display = "none";
            document.getElementById("adminDashboard").classList.add("active");
            document.getElementById("siswaDashboard").classList.remove("active");
            renderAdminPanel();
            showToast("✅ Admin berhasil login | Akses penuh", "success");
        } else {
            showToast("Password admin salah! 🔒", "error");
        }
    }

    function logoutSiswa() {
        currentSiswaName = null;
        document.getElementById("siswaDashboard").classList.remove("active");
        document.getElementById("loginScreen").style.display = "block";
        document.getElementById("adminDashboard").classList.remove("active");
        document.getElementById("namaPeminjam").value = "";
        showToast("Anda telah keluar dari mode siswa", "info");
    }

    function logoutAdmin() {
        document.getElementById("adminDashboard").classList.remove("active");
        document.getElementById("loginScreen").style.display = "block";
        document.getElementById("adminPassword").value = "";
        showToast("Admin logout", "info");
    }

    document.getElementById("siswaLoginBtn").addEventListener("click", studentLogin);
    document.getElementById("adminLoginBtn").addEventListener("click", adminLogin);
    document.getElementById("logoutSiswa").addEventListener("click", logoutSiswa);
    document.getElementById("logoutAdmin").addEventListener("click", logoutAdmin);
    document.getElementById("submitPinjamBtn").addEventListener("click", submitPeminjamanSiswa);
    
    window.cancelBooking = cancelBooking;
    window.updateStatus = updateStatus;
    window.toggleAdminPassword = toggleAdminPassword;

    loadData();
    initFlatpickr();
    document.getElementById("loginScreen").style.display = "block";
    document.getElementById("siswaDashboard").classList.remove("active");
    document.getElementById("adminDashboard").classList.remove("active");
</script>
</body>
</html>
